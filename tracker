<div class="overlay" id="overlay" onclick="closeSidebar()"></div>
<aside class="sidebar" id="sidebar"><div class="sidebar-brand"><div class="logo">D</div><div><h2>Dhara Project Tracker</h2><small>Project &amp; Activity Tracker</small></div></div><nav class="sidebar-nav"><div class="nav-sec">Main</div><div class="nav-item active" data-page="dashboard"><span class="ic">📊</span> Dashboard</div><div class="nav-item" data-page="projects"><span class="ic">📁</span> Projects <span class="nb" id="pCnt">0</span></div><div class="nav-sec">Tracking</div><div class="nav-item" data-page="materials"><span class="ic">📦</span> Materials / BOQ</div><div class="nav-item" data-page="inventory"><span class="ic">🏭</span> Inventory <span class="nb" id="invAlert">0</span></div><div class="nav-item" data-page="payments"><span class="ic">💰</span> Payments</div><div class="nav-item" data-page="maf"><span class="ic">📄</span> MAF Tracking</div><div class="nav-item" data-page="documents"><span class="ic">📋</span> Documents</div><div class="nav-sec">Business</div><div class="nav-item" data-page="tenders"><span class="ic">📝</span> Tenders</div><div class="nav-item" data-page="contacts"><span class="ic">👥</span> Contacts</div><div class="nav-item" data-page="amc"><span class="ic">🛡️</span> AMC &amp; Warranty</div><div class="nav-sec">Analysis</div><div class="nav-item" data-page="reports"><span class="ic">📈</span> Reports</div></nav></aside>
<main class="main"><header class="header"><button class="ham" onclick="toggleSidebar()" aria-label="Menu"><span></span><span></span><span></span></button><div class="search-box"><input type="text" id="gSearch" placeholder="Search projects, inventory…"></div><div class="header-right"><div class="dd"><button class="btn btn-xl">📥 <span class="btn-xl-lbl">Export</span> ▾</button><div class="ddc"><div class="ddi" onclick="exportAll()">📊 Complete Report</div><div class="ddi" onclick="exportSec('projects')">📁 Projects</div><div class="ddi" onclick="exportSec('materials')">📦 Materials</div><div class="ddi" onclick="exportSec('inventory')">🏭 Inventory</div><div class="ddi" onclick="exportSec('stockMovements')">📋 Stock Movements</div><div class="ddi" onclick="exportSec('payments')">💰 Payments</div><div class="ddi" onclick="exportSec('financial')">💵 Financial</div></div></div><div class="avatar">A</div></div></header>
