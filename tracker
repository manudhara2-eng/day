<script>
function toggleSidebar(){document.getElementById('sidebar').classList.toggle('open');document.getElementById('overlay').classList.toggle('show')}
function closeSidebar(){document.getElementById('sidebar').classList.remove('open');document.getElementById('overlay').classList.remove('show')}
document.querySelectorAll('.nav-item').forEach(function(i){i.addEventListener('click',function(){if(window.innerWidth<=768)closeSidebar()})});

var SK='dharaV4',DB=loadDB();

function defaultDB(){return{projects:[{id:'PRJ-001',name:'Adimali Taluk Hospital',customer:'C-dit',department:'',tenderRef:'',poNumber:'',poDate:'',poValue:742385,projectType:'Surveillance',status:'In Progress',startDate:'',endDate:'',description:'CCTV and network infrastructure.',priority:'Medium',location:'Adimali, Kerala',progress:40,invoiceStatus:'N/A',activities:[]},{id:'PRJ-002',name:'District Office Networking',customer:'Kerala Govt',department:'IT',tenderRef:'',poNumber:'',poDate:'',poValue:185000,projectType:'Networking',status:'Pipeline',startDate:'',endDate:'',description:'Network upgrade project.',priority:'Medium',location:'Idukki',progress:5,invoiceStatus:'N/A',activities:[]}],materials:[],payments:[],mafs:[],documents:[],tenders:[],contacts:[],amcs:[],inventory:[],stockMovements:[]}}

function loadDB(){try{var d=localStorage.getItem(SK);if(d){var p=JSON.parse(d);(p.projects||[]).forEach(function(x){if(!x.activities)x.activities=[];if(!x.invoiceStatus)x.invoiceStatus='N/A'});(p.materials||[]).forEach(function(x){if(!x.activities)x.activities=[];if(!x.invoiceStatus)x.invoiceStatus='N/A';if(!x.paymentStatus)x.paymentStatus='Unpaid';if(!x.paymentMethod)x.paymentMethod=''});if(!p.inventory)p.inventory=[];if(!p.stockMovements)p.stockMovements=[];if(!p.payments)p.payments=[];return p}return defaultDB()}catch(e){return defaultDB()}}
function saveDB(){localStorage.setItem(SK,JSON.stringify(DB))}
function gid(p){return p+'-'+Date.now().toString(36).toUpperCase()+Math.random().toString(36).slice(-3).toUpperCase()}

// ── Helpers ──
function fmt(n){return'₹'+Number(n||0).toLocaleString('en-IN')}
function N(n){return Number(n||0)}
function fD(d){if(!d)return'-';try{return new Date(d).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})}catch(e){return d}}
function fDT(d){if(!d)return'-';try{var t=new Date(d);return t.toLocaleDateString('en-IN',{day:'2-digit',month:'short'})+' '+t.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}catch(e){return d}}
function gPN(id){var p=DB.projects.find(function(x){return String(x.id)===String(id)});return p?p.name:'—'}
function gPNS(id){var n=gPN(id);return n.length>22?n.substring(0,22)+'…':n}
function gInvName(id){var i=DB.inventory.find(function(x){return x.id===id});return i?i.itemName:'Unknown'}
function gPayItem(p){if(p.linkedMatId){var m=DB.materials.find(function(x){return x.id===p.linkedMatId});if(m)return m.itemName;return p.itemName||'-'}return p.itemName||'-'}
function gv(id){var e=document.getElementById(id);return e?e.value.trim():''}

var BM={Pipeline:'b-gray','In Progress':'b-blue',Delivered:'b-cyan',Completed:'b-green','On Hold':'b-yellow',Cancelled:'b-red',Pending:'b-yellow',Ordered:'b-blue','In Transit':'b-purple',Installed:'b-green',Received:'b-green',Partial:'b-orange',Paid:'b-green',Unpaid:'b-red',Advance:'b-cyan',Overdue:'b-red',Requested:'b-yellow',Submitted:'b-blue',Expired:'b-red',Active:'b-green',Released:'b-gray',Preparing:'b-yellow',Awarded:'b-green',Lost:'b-red','Not Received':'b-red','N/A':'b-gray','Stock In':'b-green','Stock Out':'b-red',Transfer:'b-blue',Return:'b-orange',Adjustment:'b-purple','Low Stock':'b-orange','Out of Stock':'b-red','In Stock':'b-green',Receivable:'b-green',Payable:'b-red',Customer:'b-blue',OEM:'b-purple',Vendor:'b-orange'};
function sB(s){return'<span class="badge '+(BM[s]||'b-gray')+'">'+s+'</span>'}
function toast(msg,t){t=t||'ok';var c=document.getElementById('tBox'),e=document.createElement('div');e.className='toast '+t;e.textContent=(t==='ok'?'✅ ':t==='err'?'❌ ':'ℹ️ ')+msg;c.appendChild(e);setTimeout(function(){e.remove()},3000)}
function fillPF(id){var s=document.getElementById(id);if(!s)return;var v=s.value;s.innerHTML='<option value="">All Projects</option>';DB.projects.forEach(function(p){s.innerHTML+='<option value="'+p.id+'">'+p.id+' - '+p.name+'</option>'});s.value=v}
function fillLocFilter(){var s=document.getElementById('fIL');if(!s)return;var v=s.value,l={};DB.inventory.forEach(function(i){if(i.location)l[i.location]=1});s.innerHTML='<option value="">All Locations</option>';Object.keys(l).forEach(function(k){s.innerHTML+='<option value="'+k+'">'+k+'</option>'});s.value=v}

function mkSel(opts,val,ic){return opts.map(function(o){return'<option value="'+o+'"'+(String(val)===String(o)?' selected':'')+'>'+(ic&&ic[o]||'')+' '+o+'</option>'}).join('')}
function ivH(sec,id,val){val=val||'N/A';var c=val==='Received'?'sr':val==='Not Received'?'snr':val==='Partial'?'sp':'sna';return'<select class="ivs '+c+'" onchange="chgIv(\''+sec+"','"+id+"',this.value,this)\">"+mkSel(['Received','Not Received','Partial','N/A'],val,{Received:'✅','Not Received':'❌',Partial:'⏳','N/A':'➖'})+'</select>'}
function pvH(id,val){val=val||'Unpaid';var c='pv-'+(val==='Paid'?'paid':val==='Partial'?'partial':val==='Advance'?'advance':'unpaid');return'<select class="pvs '+c+'" onchange="chgPv(\''+id+"',this.value,this)\">"+mkSel(['Unpaid','Partial','Paid','Advance'],val,{Unpaid:'❌',Partial:'⏳',Paid:'✅',Advance:'💲'})+'</select>'}
function rmB(sec,id){var it=DB[sec].find(function(x){return x.id===id});return'<span class="rbdg" onclick="openAct(\''+sec+"','"+id+"')\">💬 "+(it&&it.activities?it.activities.length:0)+'</span>'}
function FI(l,id,v,o){o=o||{};return'<div class="fgi'+(o.f?' full':'')+'"><label>'+l+'</label><input'+(o.t?' type="'+o.t+'"':'')+' id="'+id+'" value="'+((v!=null)?v:'')+'"'+(o.p?' placeholder="'+o.p+'"':'')+(o.ro?' readonly style="background:#f1f5f9"':'')+(o.x?' '+o.x:'')+'></div>'}
function FS(l,id,opts,sel,f){var h='<div class="fgi'+(f?' full':'')+'"><label>'+l+'</label><select id="'+id+'">';opts.forEach(function(o){var v=Array.isArray(o)?o[0]:o,t=Array.isArray(o)?o[1]:o;h+='<option value="'+v+'"'+(String(sel)===String(v)?' selected':'')+'>'+t+'</option>'});return h+'</select></div>'}
function FT(l,id,v,f){return'<div class="fgi'+(f?' full':'')+'"><label>'+l+'</label><textarea id="'+id+'">'+(v||'')+'</textarea></div>'}

// activity
var aSec='',aId='';
function openAct(sec,id){aSec=sec;aId=id;var it=DB[sec].find(function(x){return x.id===id});if(!it)return;document.getElementById('actMT').textContent='📝 '+(it.name||it.itemName||it.id);renderAct();document.getElementById('actMdl').classList.add('open')}
function closeAct(){document.getElementById('actMdl').classList.remove('open')}
function renderAct(){var it=DB[aSec].find(function(x){return x.id===aId});if(!it)return;var acts=(it.activities||[]).slice().sort(function(a,b){return new Date(b.date)-new Date(a.date)}),tc={Update:'#3b82f6',Procurement:'#8b5cf6',Invoice:'#d97706',Delivery:'#059669',Milestone:'#dc2626',Note:'#64748b'},h='<div class="alog">';if(!acts.length)h+='<div style="text-align:center;padding:30px;color:var(--text-light)">📋 No activities</div>';else acts.forEach(function(a){h+='<div class="ai"><div class="adot" style="background:'+(tc[a.type]||'#94a3b8')+'"></div><div class="abody"><div class="atxt">'+a.text+'</div><div class="ameta"><span class="atag" style="color:'+(tc[a.type]||'#94a3b8')+'">'+a.type+'</span><span>'+fDT(a.date)+'</span></div></div><button class="adel" onclick="delAct(\''+a.id+'\')">🗑️</button></div>'});h+='</div><div class="aadd"><input type="text" id="nATxt" placeholder="Add remark…" onkeydown="if(event.key===\'Enter\')addAct()"><select id="nATy"><option>Update</option><option>Procurement</option><option>Invoice</option><option>Delivery</option><option>Milestone</option><option>Note</option></select><button class="btn btn-p btn-sm" onclick="addAct()">➕</button></div>';document.getElementById('actMB').innerHTML=h}
function addAct(){var t=document.getElementById('nATxt').value.trim();if(!t){toast('Enter remark','err');return}var it=DB[aSec].find(function(x){return x.id===aId});if(!it)return;if(!it.activities)it.activities=[];it.activities.push({id:gid('a'),text:t,type:document.getElementById('nATy').value,date:new Date().toISOString(),user:'Admin'});saveDB();toast('Added!');renderAct();refreshCur()}
function delAct(aid){if(!confirm('Delete?'))return;var it=DB[aSec].find(function(x){return x.id===aId});if(it&&it.activities){it.activities=it.activities.filter(function(a){return a.id!==aid});saveDB();toast('Deleted');renderAct();refreshCur()}}

// selection
var sels={projects:new Set(),materials:new Set(),inventory:new Set(),payments:new Set()};
function cbH(sec,id){return'<td class="cbc"><input type="checkbox" class="rcb rcb-'+sec+'" data-id="'+id+'"'+(sels[sec]&&sels[sec].has(id)?' checked':'')+' onchange="togR(this,\''+sec+'\')"></td>'}
function selAll(cb,sec){document.querySelectorAll('.rcb-'+sec).forEach(function(b){b.checked=cb.checked;cb.checked?sels[sec].add(b.dataset.id):sels[sec].delete(b.dataset.id);b.closest('tr').classList.toggle('rsel',cb.checked)});updBulk(sec)}
function togR(cb,sec){cb.checked?sels[sec].add(cb.dataset.id):sels[sec].delete(cb.dataset.id);cb.closest('tr').classList.toggle('rsel',cb.checked);updBulk(sec)}
function clrSel(sec){if(!sels[sec])return;sels[sec].clear();document.querySelectorAll('.rcb-'+sec).forEach(function(c){c.checked=false;c.closest('tr').classList.remove('rsel')});var sa=document.querySelector('.sacb[data-s="'+sec+'"]');if(sa)sa.checked=false;updBulk(sec)}
function updBulk(sec){var bar=document.getElementById('b'+sec.charAt(0).toUpperCase()+sec.slice(1));if(!bar)return;var cnt=sels[sec].size;if(!cnt){bar.classList.remove('show');return}bar.classList.add('show');bar.innerHTML='<div class="bcnt"><span class="cn">'+cnt+'</span> selected</div><div class="bacts"><button class="bbtn rd" onclick="bulkDel(\''+sec+'\')">🗑️ Delete</button><button class="bx" onclick="clrSel(\''+sec+'\')">✕</button></div>'}
function bulkDel(sec){var ids=Array.from(sels[sec]);if(!ids.length||!confirm('Delete '+ids.length+'?'))return;if(sec==='materials')ids.forEach(function(id){unlinkMaterial(id)});DB[sec]=DB[sec].filter(function(i){return ids.indexOf(i.id)===-1});sels[sec].clear();saveDB();toast(ids.length+' deleted!');refreshCur()}

// sync material
function syncMaterial(mat){
    var pj=DB.projects.find(function(p){return String(p.id)===String(mat.projectId)});
    var isDel=mat.deliveryStatus==='Delivered'||mat.deliveryStatus==='Installed';
    
    // 1. Sync Inventory
    var ix=DB.inventory.findIndex(function(i){return i.linkedMatId===mat.id});
    var inv={
        id:ix>=0?DB.inventory[ix].id:gid('INV'),
        linkedMatId:mat.id,
        itemName:mat.itemName,
        sku:mat.id,
        category:pj?pj.projectType||'Other':'Other',
        brand:mat.brand||'',
        unit:'Nos',
        currentStock:isDel?N(mat.quantity):0, 
        minStock:1,
        unitCost:N(mat.unitPrice),
        location:pj?(pj.location||pj.name):'',
        remarks:'🔗 Auto from: '+mat.itemName.substring(0,30)
    };
    if(ix>=0){
        // Preserve manual stock changes if needed, but here we enforce sync if delivered
        // inv.currentStock = DB.inventory[ix].currentStock; 
        DB.inventory[ix]=inv;
    } else if(isDel) {
        // Only create inventory record if delivered, or you can create it with 0 stock
        DB.inventory.push(inv);
    } else if (ix < 0) {
        // Create placeholder with 0 stock
        DB.inventory.push(inv);
    }

    // 2. Sync Payment (Payable to Vendor)
    var px=DB.payments.findIndex(function(p){return p.linkedMatId===mat.id});
    var ps=mat.paymentStatus==='Paid'||mat.paymentStatus==='Advance'?'Paid':mat.paymentStatus==='Partial'?'Pending':'Pending';
    
    // Only create payment if there is a cost
    if(mat.totalPrice > 0){
        var pay={
            id:px>=0?DB.payments[px].id:gid('PAY'),
            linkedMatId:mat.id,
            projectId:mat.projectId,
            type:'Payable',
            invoiceNo:mat.invoiceStatus==='Received'?'INV-'+mat.id:'',
            amount:N(mat.totalPrice),
            gst:0,
            tds:0,
            netAmount:N(mat.totalPrice),
            status:ps,
            dueDate:mat.expectedDelivery||'',
            itemName:mat.itemName,
            remarks:'🔗 '+mat.itemName.substring(0,25)+(mat.paymentMethod?' | '+mat.paymentMethod:'')
        };
        if(px>=0)DB.payments[px]=pay;else DB.payments.push(pay);
    }
}
