.aadd{display:flex;gap:6px;margin-top:12px;padding-top:12px;border-top:1px solid var(--border);flex-wrap:wrap}.aadd input[type="text"]{flex:1;min-width:120px;padding:6px 9px;border:1px solid var(--border);border-radius:var(--radius);font-size:12px;outline:none}.aadd select{padding:6px 7px;border:1px solid var(--border);border-radius:var(--radius);font-size:11px;outline:none}
