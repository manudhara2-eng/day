    else if(type==='maf'){var m5=isE?DB.mafs.find(function(x){return x.id===id})||{}:{};h='<div class="fg">'+FS('Project','f_projectId',po,m5.projectId||'',true)+FI('OEM Name','f_oemName',m5.oemName)+FI('Category','f_productCategory',m5.productCategory)+FI('MAF No','f_mafNumber',m5.mafNumber)+FI('Issue Date','f_issueDate',m5.issueDate,{t:'date'})+FI('Expiry','f_expiryDate',m5.expiryDate,{t:'date'})+FS('Status','f_mStatus',['Requested','Submitted','Active','Expired','Rejected'],m5.status||'Requested')+'</div>'}
    else if(type==='document'){var m6=isE?DB.documents.find(function(x){return x.id===id})||{}:{};h='<div class="fg">'+FS('Project','f_projectId',po,m6.projectId||'',true)+FS('Type','f_docType',['BG','Insurance','Agreement','Completion Cert','Other'],m6.type||'BG')+FI('Doc No','f_docNumber',m6.docNumber)+FI('Issue Date','f_issueDate',m6.issueDate,{t:'date'})+FI('Expiry','f_expiryDate',m6.expiryDate,{t:'date'})+FI('Amount','f_amount',m6.amount,{t:'number'})+FI('Bank/Auth','f_bankAuthority',m6.bankAuthority)+FS('Status','f_dStatus',['Active','Expired','Released','Submitted'],m6.status||'Active')+'</div>'}
    else if(type==='tender'){var m7=isE?DB.tenders.find(function(x){return x.id===id})||{}:{};h='<div class="fg">'+FI('Tender No*','f_tenderNumber',m7.tenderNumber)+FI('Portal','f_portal',m7.portal)+FI('Department','f_department',m7.department)+FI('Title*','f_title',m7.title)+FI('Est. Value','f_estimatedValue',m7.estimatedValue,{t:'number'})+FS('Status','f_tStatus',['Preparing','Submitted','Awarded','Lost','Cancelled'],m7.status||'Preparing')+FT('Remarks','f_remarks',m7.remarks,true)+'</div>'}
    else if(type==='contact'){var m8=isE?DB.contacts.find(function(x){return x.id===id})||{}:{};h='<div class="fg">'+FI('Name*','f_name',m8.name)+FI('Organization','f_organization',m8.organization)+FS('Type','f_cType',['Customer','OEM','Vendor','Other'],m8.type||'Customer')+FI('Phone','f_phone',m8.phone)+FI('Email','f_email',m8.email)+'</div>'}
    else if(type==='amc'){var m9=isE?DB.amcs.find(function(x){return x.id===id})||{}:{};h='<div class="fg">'+FS('Project','f_projectId',po,m9.projectId||'',true)+FS('Type','f_aType',['Warranty','AMC','CAMC'],m9.type||'Warranty')+FS('Status','f_aStatus',['Active','Expired','Renewed'],m9.status||'Active')+FI('Start','f_startDate',m9.startDate,{t:'date'})+FI('End','f_endDate',m9.endDate,{t:'date'})+FI('Value','f_value',m9.value,{t:'number'})+FT('Terms','f_terms',m9.terms,true)+'</div>'}

    document.getElementById('mBody').innerHTML=h;
    document.getElementById('mainModal').classList.add('open');
}

function closeModal(){document.getElementById('mainModal').classList.remove('open');curMdl=null;editId=null}

function saveModal(){
    var type=curMdl;
    if(!type) return;

    if(type==='project'){
        if(!gv('f_name')||!gv('f_customer')){toast('Name & Customer required','err');return}
        var o={
            id:editId||gid('PRJ'),
            name:gv('f_name'),
            customer:gv('f_customer'),
            department:gv('f_department'),
            location:gv('f_location'),
            poNumber:gv('f_poNumber'),
            poDate:gv('f_poDate'),
            poValue:N(gv('f_poValue')),
            status:gv('f_status'),
            priority:gv('f_priority'),
            invoiceStatus:gv('f_invoiceStatus'),
            startDate:gv('f_startDate'),
            endDate:gv('f_endDate'),
            progress:N(gv('f_progress')),
            projectType:gv('f_projectType'),
            description:gv('f_description'),
            activities:editId?(DB.projects.find(function(x){return x.id===editId})||{}).activities||[]:[]
        };
        var r=gv('f_remark');if(r)o.activities.push({id:gid('a'),text:r,type:'Note',date:new Date().toISOString(),user:'Admin'});
        
        if(editId){
            var idx=DB.projects.findIndex(function(x){return x.id===editId});
            if(idx>=0)DB.projects[idx]=o;
        }else DB.projects.push(o);
    }
    else if(type==='material'){
        if(!gv('f_itemName')){toast('Item Name required','err');return}
        var o={
            id:editId||gid('MAT'),
            projectId:gv('f_projectId'),
            itemName:gv('f_itemName'),
            brand:gv('f_brand'),
            model:gv('f_model'),
            quantity:N(gv('f_quantity')),
            unitPrice:N(gv('f_unitPrice')),
            totalPrice:N(gv('f_totalPrice')),
            vendor:gv('f_vendor'),
            deliveryStatus:gv('f_deliveryStatus'),
            invoiceStatus:gv('f_invoiceStatus'),
            paymentStatus:gv('f_paymentStatus'),
            paymentMethod:gv('f_paymentMethod'),
            expectedDelivery:gv('f_expectedDelivery'),
            activities:editId?(DB.materials.find(function(x){return x.id===editId})||{}).activities||[]:[]
        };
        var r=gv('f_remark');if(r)o.activities.push({id:gid('a'),text:r,type:'Note',date:new Date().toISOString(),user:'Admin'});
        
        if(editId){
            var idx=DB.materials.findIndex(function(x){return x.id===editId});
            if(idx>=0)DB.materials[idx]=o;
        }else DB.materials.push(o);
        
        syncMaterial(o);
    }
    else if(type==='invItem'){
        if(!gv('f_itemName')){toast('Item Name required','err');return}
        var o={
            id:editId||gid('INV'),
            itemName:gv('f_itemName'),
            sku:gv('f_sku'),
            category:gv('f_category'),
            brand:gv('f_brand'),
            unit:gv('f_unit'),
            currentStock:N(gv('f_currentStock')),
            minStock:N(gv('f_minStock')),
            unitCost:N(gv('f_unitCost')),
            location:gv('f_invLocation'),
            remarks:gv('f_remarks'),
            linkedMatId:editId?(DB.inventory.find(function(x){return x.id===editId})||{}).linkedMatId:null
        };
        if(editId){
            var idx=DB.inventory.findIndex(function(x){return x.id===editId});
            if(idx>=0)DB.inventory[idx]=o;
        }else DB.inventory.push(o);
    }
    else if(type==='stockIn'||type==='stockOut'){
        var iid=gv('f_inventoryId'), qty=N(gv('f_qty'));
        if(!iid||qty<=0){toast('Item & valid Qty required','err');return}
        var inv=DB.inventory.find(function(x){return x.id===iid});
        if(!inv){toast('Item not found','err');return}
        
        if(type==='stockOut'){
            if(inv.currentStock<qty){toast('Insufficient stock (Current: '+inv.currentStock+')','err');return}
            inv.currentStock-=qty;
        } else {
            inv.currentStock+=qty;
        }
        
        DB.stockMovements.push({
            id:gid('SM'),
            inventoryId:iid,
            type:type==='stockIn'?'Stock In':'Stock Out',
            quantity:qty,
            date:gv('f_date')||new Date().toISOString(),
            reference:gv('f_reference'),
            projectId:gv('f_projectId'),
            toLocation:gv('f_toLocation'),
            remarks:gv('f_smRemarks')
        });
    }
    else if(type==='payment'){
        if(!gv('f_amount')){toast('Amount required','err');return}
        var o={
            id:editId||gid('PAY'),
            projectId:gv('f_projectId'),
            itemName:gv('f_itemName'),
            type:gv('f_type'),
            invoiceNo:gv('f_invoiceNo'),
            amount:N(gv('f_amount')),
            gst:N(gv('f_gst')),
            tds:N(gv('f_tds')),
            netAmount:N(gv('f_netAmount')),
            status:gv('f_pStatus'),
            dueDate:gv('f_dueDate'),
            remarks:gv('f_remarks'),
            linkedMatId:editId?(DB.payments.find(function(x){return x.id===editId})||{}).linkedMatId:null
        };
        if(editId){
            var idx=DB.payments.findIndex(function(x){return x.id===editId});
            if(idx>=0)DB.payments[idx]=o;
        }else DB.payments.push(o);
    }
    else if(type==='maf'){
        var o={id:editId||gid('MAF'),projectId:gv('f_projectId'),oemName:gv('f_oemName'),productCategory:gv('f_productCategory'),mafNumber:gv('f_mafNumber'),issueDate:gv('f_issueDate'),expiryDate:gv('f_expiryDate'),status:gv('f_mStatus')};
        if(editId){var i=DB.mafs.findIndex(function(x){return x.id===editId});if(i>=0)DB.mafs[i]=o}else DB.mafs.push(o);
    }
    else if(type==='document'){
        var o={id:editId||gid('DOC'),projectId:gv('f_projectId'),type:gv('f_docType'),docNumber:gv('f_docNumber'),issueDate:gv('f_issueDate'),expiryDate:gv('f_expiryDate'),amount:N(gv('f_amount')),bankAuthority:gv('f_bankAuthority'),status:gv('f_dStatus')};
        if(editId){var i=DB.documents.findIndex(function(x){return x.id===editId});if(i>=0)DB.documents[i]=o}else DB.documents.push(o);
    }
    else if(type==='tender'){
        if(!gv('f_tenderNumber')||!gv('f_title')){toast('Required','err');return}
        var o={id:editId||gid('TND'),tenderNumber:gv('f_tenderNumber'),portal:gv('f_portal'),department:gv('f_department'),title:gv('f_title'),estimatedValue:N(gv('f_estimatedValue')),status:gv('f_tStatus'),remarks:gv('f_remarks')};
        if(editId){var i=DB.tenders.findIndex(function(x){return x.id===editId});if(i>=0)DB.tenders[i]=o}else DB.tenders.push(o);
    }
    else if(type==='contact'){
        if(!gv('f_name')){toast('Name required','err');return}
        var o={id:editId||gid('CON'),name:gv('f_name'),organization:gv('f_organization'),type:gv('f_cType'),phone:gv('f_phone'),email:gv('f_email')};
        if(editId){var i=DB.contacts.findIndex(function(x){return x.id===editId});if(i>=0)DB.contacts[i]=o}else DB.contacts.push(o);
    }
    else if(type==='amc'){
        var o={id:editId||gid('AMC'),projectId:gv('f_projectId'),type:gv('f_aType'),status:gv('f_aStatus'),startDate:gv('f_startDate'),endDate:gv('f_endDate'),value:N(gv('f_value')),terms:gv('f_terms')};
        if(editId){var i=DB.amcs.findIndex(function(x){return x.id===editId});if(i>=0)DB.amcs[i]=o}else DB.amcs.push(o);
    }

    saveDB();
    closeModal();
    toast((editId?'Updated':'Added')+'!');
    refreshCur();
}

// delete
function delItem(col,id){if(!confirm('Delete?'))return;if(col==='materials')unlinkMaterial(id);DB[col]=DB[col].filter(function(x){return x.id!==id});saveDB();toast('Deleted!');refreshCur()}

// search
document.getElementById('gSearch').addEventListener('input',function(){var q=this.value.toLowerCase();if(!q)return;var p=DB.projects.find(function(p){return p.name.toLowerCase().indexOf(q)!==-1});if(p){document.querySelector('[data-page="projects"]').click();setTimeout(function(){document.getElementById('fPQ').value=q;renderProjects()},100);return}var inv=DB.inventory.find(function(i){return i.itemName.toLowerCase().indexOf(q)!==-1||(i.sku||'').toLowerCase().indexOf(q)!==-1});if(inv){document.querySelector('[data-page="inventory"]').click();setTimeout(function(){document.getElementById('fIQ').value=q;renderInventory()},100)}});

// init
renderDash();
</script></body></html>
